{
    "name": "goodm4ven/arabicable",
    "description": "A unified Arabic language support package crafted in pure PHP with smooth Laravel integration",
    "keywords": [
        "goodm4ven",
        "laravel",
        "tallstack",
        "arabic",
        "arabicable",
        "roots",
        "stems",
        "harakat",
        "punctuation",
        "search"
    ],
    "homepage": "https://github.com/goodm4ven/PACKAGE_LARAVEL_arabicable",
    "license": "MIT",
    "authors": [
        {
            "name": "GoodM4ven",
            "email": "goodm4ven@proton.me",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.4||^8.3",
        "goodm4ven/anvil": "^1.0",
        "illuminate/contracts": "^11.0||^12.0",
        "illuminate/support": "^11.0||^12.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "goodm4ven/tailwind-merge": "^1.0",
        "larastan/larastan": "^3.0",
        "laravel/boost": "^2.0",
        "laravel/pint": "^1.14",
        "livewire/livewire": "^4.1",
        "nunomaduro/collision": "^8.8",
        "orchestra/testbench": "^10.0.0||^9.0.0",
        "pestphp/pest": "^4.0",
        "pestphp/pest-plugin-arch": "^4.0",
        "pestphp/pest-plugin-browser": "^4.0",
        "pestphp/pest-plugin-laravel": "^4.0",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan-deprecation-rules": "^2.0",
        "phpstan/phpstan-phpunit": "^2.0"
    },
    "autoload": {
        "files": [
            "src/functions.php"
        ],
        "psr-4": {
            "GoodMaven\\Arabicable\\": "src/",
            "GoodMaven\\Arabicable\\Database\\Factories\\": "database/factories/",
            "GoodMaven\\Arabicable\\Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "GoodMaven\\Arabicable\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/",
            "Workbench\\Database\\Factories\\": "workbench/database/factories/",
            "Workbench\\Database\\Seeders\\": "workbench/database/seeders/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "@prepareback"
        ],
        "sync-workbench-env": [
            "@php workbench/sync-workbench-env.php"
        ],
        "prepareback": [
            "@php vendor/bin/testbench package:purge-skeleton --ansi",
            "@sync-workbench-env",
            "@php vendor/bin/testbench workbench:create-sqlite-db",
            "@php vendor/bin/testbench package:discover --ansi",
            "@php vendor/bin/testbench workbench:build --ansi",
            "@php vendor/bin/testbench optimize:clear",
            "@php vendor/bin/testbench arabicable:seed --all --truncate"
        ],
        "preparefront": [
            "npm run build"
        ],
        "format": [
            "npm run format:blade",
            "npm run format:prettier",
            "vendor/bin/pint"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "lint": [
            "@format",
            "@analyse"
        ],
        "publishfront": [
            "@php vendor/bin/testbench vendor:publish --tag=arabicable-assets --force"
        ],
        "serve": [
            "Composer\\Config::disableProcessTimeout",
            "bash .scripts/serve-workbench.sh"
        ],
        "test": "bash .scripts/run-pest.sh",
        "testel": "bash .scripts/run-pest.sh --parallel",
        "testcov": "bash .scripts/run-pest.sh --coverage",
        "green": [
            "@prepareback",
            "@preparefront",
            "@publishfront",
            "@lint",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GoodMaven\\Arabicable\\ArabicableServiceProvider"
            ],
            "aliases": {
                "Arabicable": "GoodMaven\\Arabicable\\Facades\\Arabicable",
                "Arabic": "GoodMaven\\Arabicable\\Facades\\Arabic",
                "ArabicFilter": "GoodMaven\\Arabicable\\Facades\\ArabicFilter",
                "CamelTools": "GoodMaven\\Arabicable\\Facades\\CamelTools"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
